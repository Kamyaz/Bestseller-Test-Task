  <p class="best-sellers__product-price">
    {%- if is_mock -%}
      <span class="best-sellers__price">$104.95</span>
    {%- elsif card_product.compare_at_price > card_product.price -%}
      <span class="best-sellers__price best-sellers__price--sale">{{ card_product.price | money }}</span>
      <span class="best-sellers__price best-sellers__price--compare">{{ card_product.compare_at_price | money }}</span>
    {%- else -%}
      <span class="best-sellers__price">{{ card_product.price | money }}</span>
    {%- endif -%}
  </p>
</div>
